{
  "id": "aibook-small-scale",
  "toolbar": {
    "title": "AIBook Test"
  },
  "initialBody": 1,
  "initialState": {
    "currentBody": 1,
    "status": "Ready"
  },
  "initialData": {
    "book.title": "Welcome to AIBook",
    "book.saved": false
  },
  "bodies": {
    "editor": {
      "bodyId": 1,
      "templateId": 1,
      "template": "checkboxForm",
      "checkbox": {
        "widgetId": 101,
        "label": "Saved",
        "bind": "data.book.saved",
        "src": 1,
        "f": 102
      },
      "typeId": 1,
      "type": "column",
      "children": [
        {
          "widgetId": 111,
          "typeId": 5,
          "type": "text",
          "text": "Book Editor",
          "style": "headline"
        },
        {
          "widgetId": 112,
          "typeId": 5,
          "type": "text",
          "text": "Edit the bound title field, then save or preview."
        },
        {
          "widgetId": 113,
          "typeId": 2,
          "type": "spacer",
          "height": 12
        },
        {
          "widgetId": 102,
          "typeId": 3,
          "type": "textField",
          "label": "Book Title",
          "bind": "data.book.title",
          "src": 1,
          "f": 101
        },
        {
          "widgetId": 103,
          "typeId": 4,
          "type": "button",
          "text": "Save",
          "action": "saveBook",
          "actionId": 1
        },
        {
          "widgetId": 104,
          "typeId": 4,
          "type": "button",
          "text": "Show Preview",
          "action": "showPreview",
          "actionId": 2
        }
      ]
    },
    "preview": {
      "bodyId": 2,
      "templateId": 3,
      "template": "detail",
      "typeId": 1,
      "type": "column",
      "children": [
        {
          "widgetId": 201,
          "typeId": 5,
          "type": "text",
          "text": "Preview",
          "style": "headline"
        },
        {
          "widgetId": 202,
          "typeId": 5,
          "type": "text",
          "prefix": "Current Title: ",
          "bind": "data.book.title",
          "src": 1,
          "f": 101
        },
        {
          "widgetId": 203,
          "typeId": 5,
          "type": "text",
          "prefix": "Saved Flag: ",
          "bind": "data.book.saved",
          "src": 1,
          "f": 102
        },
        {
          "widgetId": 204,
          "typeId": 4,
          "type": "button",
          "text": "Back to Editor",
          "action": "showEditor",
          "actionId": 3
        }
      ]
    }
  }
}
