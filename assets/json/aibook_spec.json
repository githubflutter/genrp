{
  "id": "aibook-small-scale",
  "toolbar": {
    "title": "AIBook Test"
  },
  "initialBody": 1,
  "initialState": {
    "currentBody": 1,
    "status": "Ready"
  },
  "initialData": {
    "book.title": "Welcome to AIBook",
    "book.saved": false,
    "x_row": {
      "v": ["Welcome to AIBook", false]
    }
  },
  "bodies": {
    "editor": {
      "bodyId": 1,
      "t": 1,
      "actionCenters": {
        "toolbar": {
          "label": "Actions",
          "actionIds": [1, 2]
        }
      },
      "checkbox": {
        "widgetId": 101,
        "label": "Saved",
        "bind": "data.book.saved",
        "src": 1,
        "f": 102
      },
      "typeId": 1,
      "type": "column",
      "children": [
        {
          "widgetId": 111,
          "typeId": 5,
          "type": "text",
          "text": "Book Editor",
          "style": "headline"
        },
        {
          "widgetId": 112,
          "typeId": 5,
          "type": "text",
          "text": "Edit the bound title field, then save or preview."
        },
        {
          "widgetId": 113,
          "typeId": 2,
          "type": "spacer",
          "height": 12
        },
        {
          "widgetId": 102,
          "typeId": 3,
          "type": "textField",
          "label": "Book Title",
          "bind": "data.book.title",
          "src": 1,
          "f": 101
        }
      ]
    },
    "preview": {
      "bodyId": 2,
      "t": 3,
      "actionCenters": {
        "toolbar": {
          "label": "Actions",
          "actionIds": [3]
        }
      },
      "typeId": 1,
      "type": "column",
      "children": [
        {
          "widgetId": 201,
          "typeId": 5,
          "type": "text",
          "text": "Preview",
          "style": "headline"
        },
        {
          "widgetId": 202,
          "typeId": 5,
          "type": "text",
          "prefix": "Current Title: ",
          "bind": "data.book.title",
          "src": 1,
          "f": 101
        },
        {
          "widgetId": 203,
          "typeId": 5,
          "type": "text",
          "prefix": "Saved Flag: ",
          "bind": "data.book.saved",
          "src": 1,
          "f": 102
        }
      ]
    }
  }
}
